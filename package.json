{
	"name": "obsidian-multiplayer",
	"version": "0.1.0",
	"description": "Real time collaboration plugin for Obsidian",
	"main": "src/main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:mutation": "npx stryker run",
		"record-cassettes": "npx tsx scripts/record-cassettes.ts"
	},
	"keywords": [],
	"author": "Ben Rush",
	"license": "MIT",
	"devDependencies": {
		"@stryker-mutator/core": "~8.7.0",
		"@stryker-mutator/typescript-checker": "~8.7.0",
		"@stryker-mutator/vitest-runner": "~8.7.0",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^5.29.0",
		"@typescript-eslint/parser": "^5.29.0",
		"@vitest/coverage-v8": "^1.6.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.14.47",
		"fast-check": "^3.19.0",
		"jszip": "^3.10.1",
		"monkey-around": "^2.3.0",
		"nock": "^14.0.11",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vitest": "^1.6.0",
		"ws": "^8.19.0",
		"y-codemirror.next": "^0.3.2",
		"y-indexeddb": "^9.0.9",
		"y-leveldb": "^0.1.1",
		"y-protocols": "^1.0.5",
		"yjs": "^13.5.43"
	},
	"dependencies": {
		"y-websocket": "^3.0.0"
	}
}
